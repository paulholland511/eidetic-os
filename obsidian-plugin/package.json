{
  "name": "eidetic-os-obsidian-plugin",
  "version": "1.0.0",
  "description": "Obsidian plugin for Eidetic OS — search memory, browse facts, extract facts, and view stats from your local Eidetic OS server.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "eidetic-os",
    "rag",
    "memory"
  ],
  "author": "Paul Holland",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.28.0",
    "obsidian": "latest",
    "typescript": "^5.3.0"
  }
}
